# Which LLM provider to use: "openai" or "anthropic" or "groq"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Anthropic (optional — only needed if you switch LLM_PROVIDER to anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq (optional — free tier available at console.groq.com)
GROQ_API_KEY=gsk_your-key-here

# model overrides (leave blank to use defaults)
LLM_MODEL=
EMBEDDING_MODEL=

# retrieval tuning
SIMILARITY_THRESHOLD=0.35
TOP_K_RESULTS=10
RERANK_TOP_N=5

# logging
LOG_LEVEL=INFO
